# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# Playwright
node_modules/

# Runtime-generated artifacts (regenerated by main.py on every run)
data/receipts/*.pdf
form_app/uploads/*
form_app/submitted_expenses.json
logs/*.jsonl

# but keep the folders themselves tracked
!data/receipts/.gitkeep
!form_app/uploads/.gitkeep
!logs/.gitkeep

# OS / editor cruft
.DS_Store
.vscode/
.idea/
